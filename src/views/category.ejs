<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2><%= projects.category_name %></h2>
    <h3>Service Projects</h3>
    <ul>
        <% projects.forEach(project => { %>
            <li class="project"><a href="/project/<%= project.service_project_id %>"><%= project.title %></a></li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>