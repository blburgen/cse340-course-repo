<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Users</h2>
    <ul>
        <% users.forEach(user => { %>
            <li class="users">
                User Name: <%=user.name%><br>
                User Email: <%=user.email%><br>
                User Role: <%=user.role_name%>                
            </li>
        <% }); %>
    </ul>

</main>

<%- include('partials/footer') %>