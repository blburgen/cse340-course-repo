<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
        <p>Here are a few of our partner organizations:</p>
        <ul>
            <% organizations.forEach(organization => { %>
                <li><img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    <a href="/organization/<%= organization.organization_id %>"><strong><%= organization.name %></strong></a>
                    <div><strong>Email:</strong> <%= organization.contact_email %></div>
                    
                </li>
            <% }); %>
        </ul>
    </main>
<%- include('partials/footer') %>