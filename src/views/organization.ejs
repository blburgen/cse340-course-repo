<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2><%= organizationDetails.name %></h2>
    <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo">

    <p>Description: <%= organizationDetails.description %></p>
    <div><strong>Email:</strong> <%= organizationDetails.contact_email %></div>
    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/edit-organization/<%= organizationDetails.organization_id %>">Edit Organization</a></p>
    <% } %>
    <h3>Service Projects</h3>
    <ul>
        <% projects.forEach(project => { %>
            <li class="project">
                <a href="/project/<%= project.service_project_id %>">
                    <%= project.title %>
                </a>
            </li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>