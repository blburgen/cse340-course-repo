<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2><%= projectDetails.title %></h2> <%= projectDetails.description %>
    <div class="topline"><strong>Location:</strong><%= projectDetails.location %></div>
    <div><strong>Date:</strong><%= projectDetails.date.toDateString() %></div>
    <div><strong>Sponsored By:</strong><a href="/organization/<%= projectDetails.organization_id %>"><strong><%= projectDetails.name %></strong></a></div>
    <div><h3>Categories</h3>
        <a href="/assign-categories/<%= projectDetails.service_project_id %>">Edit Categories</a>
        <ul>
            <% projectCategories.forEach(category => { %>
                <li class="project">
                    <a href="/category/<%= category.category_id %>">
                        <%= category.name %>
                    </a>
                </li>
            <% }); %>
        </ul>
    </div>
</main>
<%- include('partials/footer') %>